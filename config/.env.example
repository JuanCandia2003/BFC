# ============================================
# CONFIGURACIÓN DEL ENTORNO - BFC
# ============================================
# Copiar este archivo a .env y completar con tus valores

# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/BFC

# ============================================
# CONFIGURACIÓN DE LA BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=BFC
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ============================================
# CONFIGURACIÓN DE SESIÓN
# ============================================
SESSION_LIFETIME=3600
SESSION_NAME=BFC_SESSION

# ============================================
# CONFIGURACIÓN DE SUBIDAS
# ============================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=/assets/images/

# ============================================
# CONFIGURACIÓN DE CORREO (FUTURO)
# ============================================
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@bfc.bo

# ============================================
# API KEYS (FUTURO)
# ============================================
API_KEY=
